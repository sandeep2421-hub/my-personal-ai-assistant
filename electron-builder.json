{
  "appId": "com.study.runtimebroker",
  "productName": "RuntimeBroker",
  "directories": {
    "output": "release"
  },
  "files": [
    "main.js",
    "renderer.html",
    "auth.html",
    "update.html",
    "assets/**/*",
    "node_modules/**/*"
  ],
  "publish": {
    "provider": "github",
    "owner": "sandeep2421-hub",
    "repo": "my-personal-ai-assistant"
  },
  "win": {
    "target": ["zip", "portable"]
  },
  "asar": true,
  "portable": {
    "artifactName": "RuntimeBroker.exe"
  },
  "npmRebuild": false
}
